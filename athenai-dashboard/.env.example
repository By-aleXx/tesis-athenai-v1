# ============================================================
# AthenAI - Plantilla de Variables de Entorno
# Copia este archivo como .env y rellena los valores reales
# ============================================================

# Infraestructura Remota
REMOTE_SERVER_IP=YOUR_SERVER_IP

# AWS / LocalStack
AWS_ENDPOINT_URL=http://YOUR_SERVER_IP:4566
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret

# Redis
REDIS_HOST=YOUR_SERVER_IP
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT Secrets (usar strings largos y aleatorios en producción)
JWT_SECRET_KEY=change-me-to-a-long-random-string
JWT_REFRESH_SECRET_KEY=change-me-to-another-long-random-string

# Flask
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=false

# Admin por defecto
ADMIN_PASSWORD=change-me-secure-password
ADMIN_EMAIL=admin@yourdomain.com

# API Keys para autenticación de clientes externos
VALID_API_KEYS=your_api_key_1,your_api_key_2

# IP autorizada para pruebas (sin autenticación JWT)
AUTHORIZED_TEST_IP=

# Alertas - Slack
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Alertas - Email (opcional)
ALERT_EMAIL_FROM=alerts@yourdomain.com
ALERT_EMAIL_TO=admin@yourdomain.com
ALERT_SMTP_HOST=smtp.yourdomain.com
ALERT_SMTP_PORT=587
EMAIL_API_KEY=

# Seguridad - HMAC y DB
HMAC_SECRET_KEY=change-me-to-a-long-random-string
DB_PASSWORD=change-me-secure-db-password
